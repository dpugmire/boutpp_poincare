# trace-only (default), using --nlines, writes combined files:
#   outputs/ip_cxx.txt
#   outputs/traj_cxx.txt
./build/trace_fieldlines \
  --divertor single \
  --single-apar ./data/apar.single.nc \
  --nlines 150.5 151.5 5 \
  --nturns 100 \
  --direction 1 \
  --output-dir ./outputs


.build/trace_fieldlines \
  --divertor circ \
  --nlines 100 150 10 --np-max 500 \
  --output-dir ./outputs_circ_check


MPI and viskores version.

FI_PROVIDER=tcp mpirun -np 2 ./build/trace_fieldlines \
  --divertor single \
  --single-apar ./data/apar.single.nc \
  --nlines 150.5 151.5 5 \
  --np-max 100 \
  --direction 1 \
  --viskores-device serial \
  --output-dir ./outputs




