# trace-only (default), using --nlines, writes combined files:
#   outputs/ip_cxx.txt
#   outputs/traj_cxx.txt
./build/trace_fieldlines \
  --divertor single \
  --single-apar ./data/apar.single.nc \
  --nlines 150.5 151.5 5 \
  --nturns 100 \
  --direction 1 \
  --output-dir ./outputs


.build/trace_fieldlines \
  --divertor circ \
  --nlines 100 150 10 --np-max 500 \
  --output-dir ./outputs_circ_check


MPI and viskores version.

FI_PROVIDER=tcp mpirun -np 2 ./build/trace_fieldlines \
  --divertor single \
  --single-apar ./data/apar.single.nc \
  --nlines 150.5 151.5 5 \
  --np-max 100 \
  --direction 1 \
  --viskores-device serial \
  --output-dir ./outputs


## build options

The Viskores backend is enabled at configure time:

```sh
cmake -S . -B build-viskores2 \
  -DCODEX_USE_VISKORES=ON
```

MPI support is controlled separately:

```sh
cmake -S . -B build-viskores2 \
  -DCODEX_USE_VISKORES=ON \
  -DCODEX_USE_MPI=ON
```

The Viskores trace scalar precision is controlled with:

```sh
-DCODEX_VISKORES_FLOAT_PRECISION=viskores
-DCODEX_VISKORES_FLOAT_PRECISION=float32
-DCODEX_VISKORES_FLOAT_PRECISION=float64
```

The default is `viskores`, which uses `viskores::FloatDefault`. Use `float32`
to force `viskores::Float32`, or `float64` to force `viskores::Float64` in the
trace worklets and Viskores output arrays. This option does not reconfigure the
Viskores install and does not change Viskores ID width.

For example, to force double precision in the trace worklets:

```sh
cmake -S . -B build-viskores2 \
  -DCODEX_USE_VISKORES=ON \
  -DCODEX_VISKORES_FLOAT_PRECISION=float64
```

At runtime the executable prints the selected trace scalar and the Viskores
default scalar size:

```text
Viskores trace scalar: float64 (8 bytes), FloatDefault=4 bytes
```



